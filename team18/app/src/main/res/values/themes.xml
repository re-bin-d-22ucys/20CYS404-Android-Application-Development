<resources>
    <!-- Base application theme -->
    <style name="Theme.LocalWeatherStation" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- AppCompat-supported attributes -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>
        <item name="android:background">@color/day_background</item>
        <!-- Action bar attributes -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- Transparent status bar for gradient background -->
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Theme for MainActivity without action bar -->
    <style name="Theme.LocalWeatherStation.NoActionBar" parent="Theme.LocalWeatherStation">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.LocalWeatherStation.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.LocalWeatherStation.NoActionBar</item>
    </style>
</resources>